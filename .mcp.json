{
  "mcpServers": {
    "backlog": {
      "command": "backlog",
      "args": [
        "mcp",
        "start"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic/claude-mcp-server-github"
      ]
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena-mcp-server",
        "--project",
        "${PWD}"
      ]
    }
  }
}
