# /opt/daax/.env — galway deployment environment (EXAMPLE — no live values).
#
# Copy to /opt/daax/.env on the galway host and fill in the secret values from
# ~/.secrets (the canonical secret store on galway). NEVER commit live values.
#
# docker compose gives PROCESS ENV precedence over this file: do not export any
# of the secret variables below from shell profiles (~/.zshrc), or a stale copy
# will silently override this file (caused the 2026-07-06 migrate failures —
# see .logs/decisions/deploy-ws-ticket-secret.jsonl).
#
# Values must be UNQUOTED here: compose strips surrounding quotes, but tooling
# that reads the raw line (URL builders, comparisons) does not.

# --- non-secret host config ---
HOSTNAME=galway
DAAX_WORKSPACE=/home/jpoley/jarvis/
DOCKER_GID=1001
TERMINAL_WS_URL=wss://daax.galway.poley.dev/ws
CLAWD_GATEWAY_URL=https://clawd.galway.poley.dev
CLAUDE_CONFIG_PATH=/home/jpoley/.claude.json

# --- secrets (values live in ~/.secrets on galway; placeholders only here) ---

# Clawdbot gateway bearer token (the gateway's own auth primitive).
CLAWD_GATEWAY_TOKEN=REPLACE_ME

# Terminal WS bearer-ticket HMAC secret (F1b, #95). Required in container mode.
# Generate: openssl rand -hex 32. Same value serves mint (app) + verify
# (terminal server) — one container on galway, one value.
DAAX_WS_TOKEN_SECRET=REPLACE_ME

# Proxy-secret trust boundary (F1a, #94). MUST equal the value rendered into
# the inject-proxy-secret middleware in /etc/traefik/dynamic/daax.yml
# (see traefik-daax.yml in this folder). Generate: openssl rand -hex 32.
DAAX_PROXY_SECRET=REPLACE_ME

# Strict auth (#184): Pocket ID forward-auth fronts this host, so the
# LOCAL_OPERATOR bypass stays off and uncredentialed requests fail closed.
DAAX_REQUIRE_AUTH=1

# Postgres role password (single data engine, #92/#93). Generate:
# openssl rand -hex 32. NOTE: POSTGRES_PASSWORD only applies on FIRST init of
# the daax-pg-data volume; to change it later use ALTER USER inside
# daax-postgres, then update this file.
DAAX_PG_PASSWORD=REPLACE_ME

# --- optional (compose defaults apply when unset) ---
# DAAX_PG_USER=daax
# DAAX_PG_DB=daax
# DAAX_ENV_FILE=            # host .env.local mounted read-only; /dev/null when unset
# HOME_MCP_JSON_PATH=       # host ~/.mcp.json; /dev/null when unset
# CODE_SERVER_URL=          # defaults to https://daax-code.${HOSTNAME}.poley.dev/?folder=/workspace
# CLAUDE_CONTAINER_IMAGE=   # defaults to jpoley/daax-agents:latest
# GITHUB_DAAX=              # optional GitHub token passed to the app
