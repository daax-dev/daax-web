# deploy/env/cloud.env — generic cloud-VM target (brain2daax F9 #104, §8).
# Provider-neutral: the same Compose stack on ANY cloud VM (EC2 / GCE / Azure VM /
# Hetzner) behind Traefik + Tailscale. NON-SECRET config only — see
# deploy/env/README.md. Set the *_CLOUD_* shell vars (or edit here per instance).

# --- identity / provenance (F8 Build page) ---
DAAX_HOSTNAME="${DAAX_CLOUD_HOSTNAME:-cloud}"
DAAX_DEPLOY_HOST="${DAAX_CLOUD_HOST:-cloud}"
DAAX_DEPLOY_VIA=deploy.sh/cloud

# --- workspace / paths (absolute) ---
DAAX_WORKSPACE="${DAAX_CLOUD_WORKSPACE:-/opt/daax/workspace}"
CLAUDE_CONFIG_PATH="${DAAX_CLOUD_CLAUDE_CONFIG:-/opt/daax/.claude.json}"

# --- network / public URLs ---
DAAX_NETWORK=daax-net
TERMINAL_WS_URL="${DAAX_CLOUD_WS_URL:-wss://daax.example.com/ws}"
CODE_SERVER_URL="${DAAX_CLOUD_CODE_URL:-https://daax-code.example.com/?folder=/workspace}"

# --- build strategy: BUILD ON TARGET (default) ---
# Cloud builds from local source on the VM, same as the local targets. Pull-based
# deploy is NOT enabled by default: the split topology needs BOTH a daax-web AND a
# daax-terminal image, but .github/workflows/publish-images.yml currently publishes
# only ghcr.io/daax-dev/daax-web (+ code-server) — there is no published
# daax-terminal image yet. Enabling pull here would resolve daax-terminal to a
# nonexistent ref. When a daax-terminal image is published, switch to pull by
# setting (compose already reads ${DAAX_IMAGE}/${DAAX_TERMINAL_IMAGE}):
#   DAAX_DEPLOY_PULL=1
#   DAAX_IMAGE=ghcr.io/daax-dev/daax-web:latest
#   DAAX_TERMINAL_IMAGE=ghcr.io/daax-dev/daax-terminal:latest
# Follow-up: publish daax-terminal so cloud VMs need not build. Until then, a
# mistaken pull fails closed at the build phase (no silent wrong-image deploy).
DAAX_DEPLOY_PULL=0

# --- strict auth: Traefik + Pocket ID forward-auth enforced ---
DAAX_REQUIRE_AUTH=1

# --- Postgres topology ---
# DEFAULT: compose-local Postgres (works on any VM, zero lock-in). Required
# secret is DAAX_PG_PASSWORD.
DAAX_PG_MANAGED=0
DAAX_REQUIRED_SECRETS="DAAX_WS_TOKEN_SECRET DAAX_PROXY_SECRET DAAX_PG_PASSWORD"

# MANAGED Postgres (RDS / Cloud SQL / Neon / Azure): NOT YET SUPPORTED.
# deploy.sh fails closed in preflight when DAAX_PG_MANAGED=1, because
# deploy/docker-compose.yml hardcodes DATABASE_URL to the compose-local
# postgres for the migrate and daax services — an exported managed DATABASE_URL
# never reaches a container, and the app would silently use compose-local
# Postgres. Wiring the DATABASE_URL swap through compose (and dropping the
# local Postgres coupling) is a documented follow-up
# (deploy/iac/cloud/README.md, deploy/env/README.md).
